{
  "name": "train-planner",
  "version": "1.3.4",
  "description": "多策略购票方案规划工具 —— 直达 / 换乘 / 买长乘短 / 买短乘长 / 分段购票",
  "main": "server.js",
  "bin": "server.js",
  "pkg": {
    "assets": ["public/**/*"],
    "targets": ["node18-win-x64", "node18-linux-x64", "node18-macos-x64", "node18-macos-arm64"],
    "outputPath": "dist"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "pkg . --targets node18-win-x64,node18-linux-x64,node18-macos-x64,node18-macos-arm64 --output dist/train-planner",
    "build:win": "pkg . --targets node18-win-x64 --output dist/train-planner-win.exe",
    "build:mac": "pkg . --targets node18-macos-arm64 --output dist/train-planner-mac",
    "build:linux": "pkg . --targets node18-linux-x64 --output dist/train-planner-linux"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1311523821/train-planner.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/1311523821/train-planner/issues"
  },
  "homepage": "https://github.com/1311523821/train-planner#readme",
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "node-fetch": "^2.7.0"
  }
}

